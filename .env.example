# OpenAI
OPENAI_API_KEY=sk-your-key-here
# Choose a current Responses API model from https://developers.openai.com/api/docs/models
OPENAI_MODEL=gpt-5.4-mini

# App
APP_BASE_URL=http://localhost:3000
TIMEZONE=America/Los_Angeles

# Supabase - use service role only on the server, never in browser/client code
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Notion internal integration
NOTION_TOKEN=secret_your_notion_integration_token
NOTION_PROPOSED_ACTIONS_DATA_SOURCE_ID=your_notion_data_source_id
NOTION_PROPOSED_ACTIONS_DATABASE_ID=your_notion_database_id
NOTION_TASKS_DATABASE_ID=optional_for_later
NOTION_JOURNAL_DATABASE_ID=optional_for_later
NOTION_GOALS_DATABASE_ID=optional_for_later

# Future phases - document names only until implemented
CRON_SECRET=
GOOGLE_CLIENT_ID=
